default_platform(:android)

platform :android do

  desc "Increment build number"
  lane :bump do
    gradle_file = "../app/build.gradle.kts"

    # Read current build number
    content = File.read(gradle_file)
    current_build = content.match(/val buildNumber = (\d+)/)[1].to_i
    new_build = current_build + 1

    # Update build number
    new_content = content.gsub(/val buildNumber = \d+/, "val buildNumber = #{new_build}")
    File.write(gradle_file, new_content)

    UI.success("Build number incremented: #{current_build} -> #{new_build}")
    new_build
  end

  desc "Build debug APK"
  lane :build_debug do
    gradle(
      task: "assembleDevStandardDebug"
    )
  end

  desc "Build release AAB for Play Store"
  lane :build_release do
    gradle(
      task: "bundleProdStandardRelease"
    )
  end

  desc "Build staging APK"
  lane :build_staging do
    gradle(
      task: "assembleStagingStandardDebug"
    )
  end

  desc "Run tests"
  lane :test do
    gradle(
      task: "testDevStandardDebugUnitTest"
    )
  end

  # Reads a key from local.properties (Fastfile runs from the fastlane/ dir, so ../local.properties).
  def read_local_property(key)
    file = File.join(Dir.pwd, "..", "local.properties")
    return nil unless File.exist?(file)
    line = File.readlines(file).find { |l| l.strip.start_with?("#{key}=") }
    line&.split("=", 2)&.last&.strip
  end

  desc "Firebase Test Lab robo pre-flight: drives the recorded login robo-script against the matching " \
       "environment's APK so a broken login / crash is caught before upload. Pass env: dev|staging|prod " \
       "(default prod) so the flavor AND credentials match the backend that build points at. Skips " \
       "gracefully if no Firebase project is configured (RP_FIREBASE_PROJECT env or firebase.project " \
       "in local.properties)."
  lane :robo_test do |options|
    project = ENV["RP_FIREBASE_PROJECT"] || read_local_property("firebase.project")
    if project.nil? || project.empty?
      UI.important("⚠️  robo_test skipped: no Firebase project configured " \
                   "(set RP_FIREBASE_PROJECT or firebase.project in local.properties).")
      next
    end

    env = (options[:env] || "prod").to_s          # dev | staging | prod — must match the deploy's flavor
    flavor = env.capitalize                        # Dev | Staging | Prod

    # The robo-script bakes in login credentials, which are valid only against THAT environment's backend
    # (prod creds work on api-public, not on dev/staging). Use a per-env script if present; the default
    # script holds prod creds, so non-prod envs without their own script are skipped rather than fed the
    # wrong credentials (which would fail login and false-fail the gate).
    env_script = "app/src/test/resources/robo-script.#{env}.json"
    script =
      if File.exist?(File.join(Dir.pwd, "..", env_script))
        env_script
      elsif env == "prod"
        "app/src/test/resources/robo-script.json"
      else
        nil
      end
    if script.nil?
      UI.important("⚠️  robo_test skipped for '#{env}': no #{env_script} (the default robo-script.json " \
                   "carries prod credentials and won't authenticate against the #{env} backend).")
      next
    end

    # Robo runs against an APK (not an AAB).
    gradle(task: "assemble#{flavor}StandardRelease")
    apk = "app/build/outputs/apk/#{env}Standard/release/app-#{env}-standard-release.apk"

    UI.message("🤖 Firebase Test Lab robo (#{env}) with #{script} on project #{project}...")
    sh(
      "gcloud firebase test android run --type robo " \
      "--app '../#{apk}' " \
      "--robo-script '../#{script}' " \
      "--timeout 5m " \
      "--project '#{project}'"
    )
    UI.success("✅ Firebase Test Lab robo (#{env}) passed")
  end

  desc "Bump version and build debug"
  lane :bump_and_build do
    bump
    build_debug
  end

  desc "Build dev release AAB"
  lane :build_dev_release do
    gradle(
      task: "bundleDevStandardRelease"
    )
  end

  desc "Deploy dev build to Play Store internal track"
  lane :deploy_dev do
    build = bump
    build_dev_release
    upload_dev
    finalize_sentry(build: build)
  end

  desc "Upload dev AAB to Play Store internal track (skip build)"
  lane :upload_dev do
    upload_to_play_store(
      track: "internal",
      release_status: "draft",
      aab: "app/build/outputs/bundle/devStandardRelease/app-dev-standard-release.aab"
    )
  end

  desc "Deploy to Play Store internal track"
  lane :deploy_internal do
    build = bump
    robo_test(env: "prod")
    build_release
    upload_to_play_store(
      track: "internal",
      release_status: "draft",
      skip_upload_apk: true
    )
    finalize_sentry(build: build)
  end

  desc "Deploy to Play Store open testing track"
  lane :deploy_open do
    build = bump
    robo_test(env: "prod")
    build_release
    upload_to_play_store(
      track: "beta",
      release_status: "completed",
      skip_upload_apk: true
    )
    finalize_sentry(build: build)
  end

  desc "Build staging release AAB"
  lane :build_staging_release do
    gradle(
      task: "bundleStagingStandardRelease"
    )
  end

  desc "Deploy staging build to Play Store closed testing track"
  lane :deploy_staging do
    build = bump
    build_staging_release
    upload_to_play_store(
      track: "alpha",
      release_status: "completed",
      aab: "app/build/outputs/bundle/stagingStandardRelease/app-staging-standard-release.aab"
    )
    finalize_sentry(build: build)
  end

  desc "Deploy to Play Store beta track"
  lane :deploy_beta do
    build = bump
    robo_test(env: "prod")
    build_release
    upload_to_play_store(
      track: "beta",
      release_status: "completed",
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
    finalize_sentry(build: build)
  end

  desc "Deploy to Play Store production"
  lane :deploy_production do
    build = bump
    robo_test(env: "prod")
    build_release
    upload_to_play_store(
      track: "production",
      release_status: "completed",
      skip_upload_apk: true
    )
    finalize_sentry(build: build)
  end

  desc "Clean build"
  lane :clean do
    gradle(
      task: "clean"
    )
  end

  private_lane :finalize_sentry do |options|
    build = options[:build]
    gradle_content = File.read("../app/build.gradle.kts")
    version_base = gradle_content.match(/versionName = "([^(]+)\(/)[1].strip
    version = "com.rocketplantech.rocketplan@#{version_base} (#{build})+#{build}"
    sh("sentry-cli releases new '#{version}' --org rocketplan-technologies-inc --project android")
    sh("sentry-cli releases finalize '#{version}' --org rocketplan-technologies-inc --project android")
  end

end
