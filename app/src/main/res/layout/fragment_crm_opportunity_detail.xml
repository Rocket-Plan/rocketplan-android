<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ProgressBar
        android:id="@+id/loadingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/contentScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Opportunity Name -->
            <TextView
                android:id="@+id/opportunityName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/dark_text_rp"
                android:textSize="@dimen/text_size_headline"
                android:textStyle="bold"
                tools:text="New Restoration Lead" />

            <!-- Status badge -->
            <TextView
                android:id="@+id/opportunityStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/badge_type"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:textColor="@color/main_purple"
                android:textSize="@dimen/text_size_body_small"
                android:visibility="gone"
                tools:text="Open"
                tools:visibility="visible" />

            <!-- Contact -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/crm_label_contact"
                android:textColor="@color/light_text_rp"
                android:textSize="@dimen/text_size_body_small" />

            <TextView
                android:id="@+id/opportunityContact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/dark_text_rp"
                android:textSize="@dimen/text_size_body_large"
                tools:text="Tom Joad" />

            <!-- Pipeline -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/crm_label_pipeline"
                android:textColor="@color/light_text_rp"
                android:textSize="@dimen/text_size_body_small" />

            <TextView
                android:id="@+id/opportunityPipeline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/dark_text_rp"
                android:textSize="@dimen/text_size_body_large"
                tools:text="Sales Pipeline" />

            <!-- Stage -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/crm_label_stage"
                android:textColor="@color/light_text_rp"
                android:textSize="@dimen/text_size_body_small" />

            <TextView
                android:id="@+id/opportunityStage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/dark_text_rp"
                android:textSize="@dimen/text_size_body_large"
                tools:text="New Lead" />

            <!-- Monetary Value -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/crm_label_monetary_value"
                android:textColor="@color/light_text_rp"
                android:textSize="@dimen/text_size_body_small" />

            <TextView
                android:id="@+id/opportunityValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/dark_text_rp"
                android:textSize="@dimen/text_size_body_large"
                tools:text="$600.00" />

            <!-- Source -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/crm_label_source"
                android:textColor="@color/light_text_rp"
                android:textSize="@dimen/text_size_body_small" />

            <TextView
                android:id="@+id/opportunitySource"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/dark_text_rp"
                android:textSize="@dimen/text_size_body_large"
                tools:text="Website" />

            <!-- Date Added -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/crm_label_date_added"
                android:textColor="@color/light_text_rp"
                android:textSize="@dimen/text_size_body_small" />

            <TextView
                android:id="@+id/opportunityDateAdded"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/dark_text_rp"
                android:textSize="@dimen/text_size_body_large"
                tools:text="Feb 14, 2026" />

            <!-- Custom Fields -->
            <LinearLayout
                android:id="@+id/customFieldsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                android:visibility="gone" />

            <!-- Edit Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/editButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/crm_edit_opportunity" />

            <!-- Delete Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/deleteButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp"
                android:text="@string/delete"
                android:textColor="@android:color/holo_red_dark"
                app:strokeColor="@android:color/holo_red_dark" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
