<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/materialGoalTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/rocketdry_goal_add_title"
        android:textColor="@color/dark_text_rp"
        android:textSize="@dimen/text_size_headline"
        android:textStyle="bold" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/materialNameInputLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:hint="@string/rocketdry_goal_material_hint"
        app:boxStrokeColor="@color/main_purple"
        app:hintTextColor="@color/light_text_rp">

        <com.google.android.material.textfield.MaterialAutoCompleteTextView
            android:id="@+id/materialNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapWords"
            android:imeOptions="actionNext" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/targetMoistureInputLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="@string/rocketdry_goal_target_hint"
        app:boxStrokeColor="@color/main_purple"
        app:hintTextColor="@color/light_text_rp"
        app:suffixText="%"
        app:suffixTextColor="@color/light_text_rp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/targetMoistureInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:textSize="@dimen/text_size_headline" />

    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cancelMaterialGoalButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="@string/cancel"
            app:strokeColor="@color/main_purple"
            android:textColor="@color/main_purple" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveMaterialGoalButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="@string/save"
            android:backgroundTint="@color/main_purple" />
    </LinearLayout>

</LinearLayout>
