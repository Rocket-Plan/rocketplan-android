<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardElevation="0dp"
    app:cardUseCompatPadding="false"
    app:strokeColor="@color/light_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/personName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textSize="@dimen/text_size_body_large"
                    android:textStyle="bold"
                    tools:text="John Doe" />

                <TextView
                    android:id="@+id/adminBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/badge_admin"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="@string/admin_badge"
                    android:textColor="@android:color/white"
                    android:textSize="@dimen/text_size_caption"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/youBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/badge_you"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="@string/you_badge"
                    android:textColor="@color/main_purple"
                    android:textSize="@dimen/text_size_caption"
                    android:visibility="gone"
                    tools:visibility="visible" />
            </LinearLayout>

            <TextView
                android:id="@+id/personEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/light_text_rp"
                android:textSize="@dimen/text_size_body_small"
                tools:text="john.doe@example.com" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/editPersonButton"
            android:layout_width="@dimen/icon_size_action"
            android:layout_height="@dimen/icon_size_action"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/edit_person"
            android:padding="8dp"
            android:src="@drawable/ic_edit"
            android:visibility="gone"
            app:tint="@color/main_purple"
            tools:visibility="visible" />

        <ImageButton
            android:id="@+id/deletePersonButton"
            android:layout_width="@dimen/icon_size_action"
            android:layout_height="@dimen/icon_size_action"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/delete_person"
            android:padding="8dp"
            android:src="@drawable/ic_close"
            android:visibility="gone"
            app:tint="@color/dark_red"
            tools:visibility="visible" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
