<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:rippleColor="?attr/colorControlHighlight">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Status indicator -->
        <View
            android:id="@+id/timecardStatusIndicator"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="12dp"
            android:background="@color/main_purple" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Date -->
            <TextView
                android:id="@+id/timecardItemDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/dark_text_rp"
                android:textSize="@dimen/text_size_body"
                android:textStyle="bold"
                tools:text="Today, Jan 30" />

            <!-- Time range -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/timecardItemTimeIn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/light_text_rp"
                    android:textSize="@dimen/text_size_body_small"
                    tools:text="9:00 AM" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:text="@string/timecard_time_separator"
                    android:textColor="@color/light_text_rp"
                    android:textSize="@dimen/text_size_body_small" />

                <TextView
                    android:id="@+id/timecardItemTimeOut"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/light_text_rp"
                    android:textSize="@dimen/text_size_body_small"
                    tools:text="5:30 PM" />
            </LinearLayout>

            <!-- Type and notes -->
            <TextView
                android:id="@+id/timecardItemType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/main_purple"
                android:textSize="@dimen/text_size_body_small"
                tools:text="Standard" />

            <TextView
                android:id="@+id/timecardItemNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/light_text_rp"
                android:textSize="@dimen/text_size_body_small"
                android:visibility="gone"
                tools:text="Working on drying equipment setup"
                tools:visibility="visible" />

        </LinearLayout>

        <!-- Duration -->
        <TextView
            android:id="@+id/timecardItemDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="12dp"
            android:textColor="@color/dark_text_rp"
            android:textSize="@dimen/text_size_title"
            android:textStyle="bold"
            android:fontFamily="monospace"
            tools:text="8:30" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
