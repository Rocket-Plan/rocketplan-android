<?xml version="1.0" encoding="utf-8"?>
<com.example.rocketplan_android.ui.components.SquareMaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@android:color/transparent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/roomThumbnail"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:contentDescription="@string/photos"
            android:scaleType="centerCrop"
            android:src="@drawable/bg_room_placeholder"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/roomGradientOverlay"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/room_card_gradient"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineTextZone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.70" />

        <FrameLayout
            android:id="@+id/roomIconContainer"
            android:layout_width="@dimen/icon_size_tile"
            android:layout_height="@dimen/icon_size_tile"
            app:layout_constraintBottom_toTopOf="@id/guidelineTextZone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/roomTypeIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:background="@drawable/bg_icon_circle_purple"
                android:contentDescription="@string/location_icon"
                android:padding="16dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_door" />
        </FrameLayout>

        <TextView
            android:id="@+id/roomScopeTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_room_scope_total"
            android:ellipsize="end"
            android:paddingStart="10dp"
            android:paddingTop="4dp"
            android:paddingEnd="10dp"
            android:paddingBottom="4dp"
            android:singleLine="true"
            android:textColor="@android:color/white"
            android:textSize="@dimen/text_size_badge"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="$1.2k" />

        <LinearLayout
            android:id="@+id/processingContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/guidelineTextZone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ProgressBar
                android:id="@+id/loadingSpinner"
                style="@android:style/Widget.DeviceDefault.Light.ProgressBar.Large"
                android:layout_width="@dimen/icon_size_card_large"
                android:layout_height="@dimen/icon_size_card_large"
                android:indeterminate="true" />

            <TextView
                android:id="@+id/processingProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_room_scope_total"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:textColor="@android:color/white"
                android:textSize="@dimen/text_size_body_small"
                android:textStyle="bold"
                tools:text="3/5" />
        </LinearLayout>

        <TextView
            android:id="@+id/roomTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:textColor="@android:color/white"
            android:textSize="@dimen/text_size_card_title"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/photoCount"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:text="Basement" />

        <TextView
            android:id="@+id/photoCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:textColor="@android:color/white"
            android:textSize="@dimen/text_size_card_subtitle"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:text="7 Photos" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.example.rocketplan_android.ui.components.SquareMaterialCardView>
