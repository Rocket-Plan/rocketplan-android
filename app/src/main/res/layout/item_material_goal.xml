<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/light_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <!-- Left: Name + Date -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/goalName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/dark_text_rp"
                android:textSize="@dimen/text_size_body_large"
                android:textStyle="bold"
                tools:text="Baseboard - East Wall" />

            <TextView
                android:id="@+id/goalUpdated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/light_text_rp"
                android:textSize="@dimen/text_size_caption"
                tools:text="Feb 6, 3:30pm" />
        </LinearLayout>

        <!-- Vertical divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:background="@color/light_border" />

        <!-- Goal Average column -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/goalTarget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/dark_text_rp"
                android:textSize="24sp"
                android:textStyle="bold"
                tools:text="5" />

            <TextView
                android:id="@+id/goalLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rocketdry_goal_average_short"
                android:textColor="@color/light_text_rp"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Latest Average column -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/goalLatestValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:textStyle="bold"
                tools:text="4"
                tools:textColor="@color/main_purple" />

            <TextView
                android:id="@+id/latestLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rocketdry_latest_average_short"
                android:textColor="@color/light_text_rp"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Add log (+) button -->
        <ImageView
            android:id="@+id/addLogButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/rocketdry_add_log"
            android:padding="4dp"
            android:src="@drawable/ic_add_circle_outline"
            app:tint="@color/light_text_rp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
